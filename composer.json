{
	"name": "nextcloud/calorietracker",
	"description": "Track your daily calorie intake",
	"license": "AGPL-3.0-or-later",
	"config": {
		"allow-plugins": {
			"bamarni/composer-bin-plugin": true
		},
		"optimize-autoloader": true,
		"classmap-authoritative": false,
		"platform": {
			"php": "8.1"
		},
		"sort-packages": true
	},
	"extra": {
		"bamarni-bin": {
			"bin-links": true,
			"forward-command": true
		}
	},
	"autoload": {
		"psr-4": {
			"OCA\\CalorieTracker\\": "lib/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"OCA\\CalorieTracker\\Tests\\": "tests/"
		}
	},
	"require-dev": {
		"bamarni/composer-bin-plugin": "^1.8",
		"nextcloud/ocp": "dev-master"
	},
	"scripts": {
		"lint": "find . -name \\*.php -not -path './vendor/*' -not -path './vendor-bin/*' -print0 | xargs -0 -n1 php -l",
		"post-install-cmd": [
			"@php -r \"if (file_exists('vendor/bamarni/composer-bin-plugin/src/Command/BinCommand.php')) { passthru('composer bin all install --ansi', \\$exitCode); exit(\\$exitCode); }\""
		],
		"post-update-cmd": [
			"@php -r \"if (file_exists('vendor/bamarni/composer-bin-plugin/src/Command/BinCommand.php')) { passthru('composer bin all install --ansi', \\$exitCode); exit(\\$exitCode); }\""
		],
		"test:unit": "vendor-bin/phpunit/vendor/phpunit/phpunit/phpunit -c tests/phpunit.xml"
	}
}